# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
# Firebase service account JSON dosyasının yolu (lokal için)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_service_account.json
# VEYA JSON içeriğini stringe dönüştürüp buraya yapıştır (Railway/Render için)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Play (Faz 3'te)
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.omrapp

# Geliştirme modu: Firebase auth'u atla (true/false)
SKIP_AUTH=false

# İlk kayıtta verilen ücretsiz kredi
INITIAL_FREE_CREDITS=500
