# ─── Ortam ────────────────────────────────────────────────────────────────────
# development | production | test
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── API Anahtarları ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase — birini seç (Railway için B64 önerilir)
# Seçenek 1: Base64 encoded JSON (Railway için önerilen)
FIREBASE_SERVICE_ACCOUNT_JSON_B64=

# Seçenek 2: Düz JSON string
FIREBASE_SERVICE_ACCOUNT_JSON=

# Seçenek 3: Dosya yolu (lokal geliştirme)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_service_account.json

# ─── Auth ─────────────────────────────────────────────────────────────────────
# UYARI: PRODUCTION'DA ASLA true YAPMA
SKIP_AUTH=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Production'da explicit origin listesi gir (virgülle ayrılmış)
# Örnek: https://myapp.com,https://api.myapp.com
# Boş bırakılırsa development'ta * (herkese açık), production'da engellenir
CORS_ORIGINS=

# ─── Görüntü İşleme ───────────────────────────────────────────────────────────
TARAMA_DPI=150
MAX_GORUNTU_PX=1200
MAX_UPLOAD_SIZE_MB=10
MAX_EXCEL_SIZE_MB=5

# ─── OMR Eşikleri ─────────────────────────────────────────────────────────────
GUVEN_ESIGI=0.70
BENZERLIK_ESIGI=0.85

# ─── Batch İşleme ─────────────────────────────────────────────────────────────
MAX_BATCH_SIZE=30
THREAD_WORKERS=5

# ─── Kredi ────────────────────────────────────────────────────────────────────
INITIAL_FREE_CREDITS=500
AD_REWARD_CREDITS=10

# ─── Admin Streamlit ──────────────────────────────────────────────────────────
# İlk çalıştırmada admin kullanıcısı için şifre belirle
# Boş bırakılırsa admin kullanıcısı oluşturulmaz
ADMIN_INITIAL_PASSWORD=

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Sentry DSN (boş bırakılırsa Sentry devre dışı)
SENTRY_DSN=
